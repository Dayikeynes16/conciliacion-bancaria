###############################################################################
# Conciliación Bancaria – Environment Configuration
#
# Copy this file to .env and fill in the values for your environment.
# Run `php artisan key:generate` (or via Sail) to set APP_KEY.
###############################################################################

#------------------------------------------------------------------------------
# Application
#------------------------------------------------------------------------------
APP_NAME="Conciliación Bancaria"
APP_ENV=local            # local | production | staging
APP_KEY=                 # Generated with: php artisan key:generate
APP_DEBUG=true           # MUST be false in production
APP_URL=http://localhost

APP_LOCALE=es
APP_FALLBACK_LOCALE=es
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

#------------------------------------------------------------------------------
# Logging
#------------------------------------------------------------------------------
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug          # debug | info | warning | error (use "error" in production)

#------------------------------------------------------------------------------
# Database (MySQL via Sail)
#------------------------------------------------------------------------------
DB_CONNECTION=mysql
DB_HOST=mysql            # "mysql" when using Sail, "127.0.0.1" otherwise
DB_PORT=3306
DB_DATABASE=laravel
DB_USERNAME=sail
DB_PASSWORD=password     # Change in production!

#------------------------------------------------------------------------------
# Session
#------------------------------------------------------------------------------
SESSION_DRIVER=database
SESSION_LIFETIME=60
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=null

#------------------------------------------------------------------------------
# Services (Drivers)
#------------------------------------------------------------------------------
BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis     # "redis" for async jobs (imports/exports)
CACHE_STORE=redis

#------------------------------------------------------------------------------
# Redis (used by Sail containers)
#------------------------------------------------------------------------------
REDIS_CLIENT=phpredis
REDIS_HOST=redis         # "redis" when using Sail, "127.0.0.1" otherwise
REDIS_PASSWORD=null
REDIS_PORT=6379

#------------------------------------------------------------------------------
# Mail (Mailpit in dev, SMTP in production)
#------------------------------------------------------------------------------
MAIL_MAILER=smtp         # Use "log" to disable sending in dev
MAIL_SCHEME=null
MAIL_HOST=mailpit        # "mailpit" for Sail, your SMTP host in production
MAIL_PORT=1025           # 1025 for Mailpit, 465/587 for production SMTP
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null     # ssl | tls | null
MAIL_FROM_ADDRESS="noreply@example.com"
MAIL_FROM_NAME="${APP_NAME}"

#------------------------------------------------------------------------------
# AWS / S3 (optional – only if using S3 for file storage)
#------------------------------------------------------------------------------
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

#------------------------------------------------------------------------------
# Vite (Frontend build)
#------------------------------------------------------------------------------
VITE_APP_NAME="${APP_NAME}"

#------------------------------------------------------------------------------
# Sail Port Forwarding (local dev only – avoid conflicts with other projects)
# Uncomment and adjust if default ports are already in use.
#------------------------------------------------------------------------------
# APP_PORT=8085
# VITE_PORT=5174
# FORWARD_DB_PORT=3307
# FORWARD_REDIS_PORT=6380
# FORWARD_MAILPIT_PORT=1026
# FORWARD_MAILPIT_DASHBOARD_PORT=8026
